# ══════════════════════════════════════
# C-Tracks — Variables de Entorno
# ══════════════════════════════════════

# Base de datos
POSTGRES_USER=ctracks
POSTGRES_PASSWORD=CAMBIAR_ESTA_PASSWORD
POSTGRES_DB=ctracks
DATABASE_URL=postgresql+asyncpg://ctracks:CAMBIAR_ESTA_PASSWORD@db:5432/ctracks

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=GENERAR_CON_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=C-Tracks
APP_ENV=development
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost"]

# CFDI (futuro)
# CFDI_PROVIDER_URL=
# CFDI_API_KEY=
